<resources>
    <!-- Compose draws the whole UI; this just controls the window/system bars and
         the pre-Compose splash background. -->
    <style name="Theme.TinyDj" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/body</item>
        <item name="android:statusBarColor">@color/body</item>
        <item name="android:navigationBarColor">@color/body</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
